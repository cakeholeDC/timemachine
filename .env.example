# Password for the Samba share (used when connecting from macOS)
TM_PASSWORD=timemachine

# Network share name visible in Finder
TM_SHARENAME=timemachine.home.arpa

# Path where the external drive is mounted on the host
# Set this to the value printed by: sudo ./scripts/mount-drive.sh
TM_DEVICE_MOUNT_POINT=/tm_data

# Time Machine backup quota — value + unit (e.g. "2 T", "500 G", "1000 M")
# Set this to the value printed by: sudo ./scripts/mount-drive.sh
TM_VOLUME_SIZE_LIMIT=500 G
